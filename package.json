{
    "name": "mainsail-cnc",
    "version": "0.2.1",
    "private": true,
    "type": "module",
    "description": "A web interface for Klipper-based CNC machines",
    "author": {
        "name": "Isaac Eliape"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/isaaceliape/mainsail-cnc.git"
    },
    "bugs": {
        "url": "https://github.com/isaaceliape/mainsail-cnc/issues"
    },
    "homepage": "https://github.com/isaaceliape/mainsail-cnc",
    "license": "GPL-3.0",
    "scripts": {
        "serve": "vite serve",
        "dev": "tmux has-session -t mainsail-cnc 2>/dev/null || tmux new-session -d -s mainsail-cnc 'vite'",
        "build": "vite build",
        "format": "bun run format:base -- --write",
        "format:base": "prettier .",
        "format:check": "bun run format:base -- --check",
        "lint": "eslint src",
        "lint:fix": "bun run lint -- --fix",
        "i18n-extract": "vue-i18n-extract --vueFiles './src/**/{*.?(js|ts|vue),.i18nignore}' --languageFiles './src/locales/*.json'",
        "preview": "vite preview",
        "start": "vite build && vite preview",
        "test": "start-server-and-test preview http://127.0.0.1:4173/ 'cypress run'",
        "test:ui": "cypress open",
        "test:unit": "NODE_OPTIONS=\"${NODE_OPTIONS:---max-old-space-size=4096}\" vitest run",
        "test:unit:watch": "NODE_OPTIONS=\"${NODE_OPTIONS:---max-old-space-size=4096}\" vitest",
        "test:coverage": "NODE_OPTIONS=\"${NODE_OPTIONS:---max-old-space-size=4096}\" vitest run --coverage",
        "test:scripts": "bats tests/scripts/"
    },
    "dependencies": {
        "@codemirror/commands": "^6.0.1",
        "@codemirror/lang-css": "^6.0.0",
        "@codemirror/lang-json": "^6.0.0",
        "@codemirror/language": "^6.2.0",
        "@codemirror/legacy-modes": "^6.1.0",
        "@codemirror/search": "^6.0.0",
        "@codemirror/state": "^6.1.0",
        "@codemirror/view": "^6.0.3",
        "@jaames/iro": "^5.5.2",
        "@lezer/highlight": "^1.0.0",
        "@sindarius/gcodeviewer": "^3.7.17",
        "@uiw/codemirror-theme-vscode": "^4.23.13",
        "@vueuse/core": "^11.0.0",
        "axios": "^1.16.0",
        "codemirror": "^6.0.1",
        "core-js": "^3.16.0",
        "detect-browser": "^5.3.0",
        "echarts": "^5.5.0",
        "echarts-gl": "^2.0.8",
        "hls.js": "^1.3.3",
        "jmuxer": "^2.0.5",
        "js-sha256": "^0.10.0",
        "lodash.kebabcase": "^4.1.1",
        "lodash.throttle": "^4.1.1",
        "mitt": "^3.0.1",
        "overlayscrollbars": "^2.10.0",
        "overlayscrollbars-vue": "^0.5.10",
        "pinia": "^2.3.0",
        "regenerator-runtime": "^0.14.0",
        "resize-observer-polyfill": "^1.5.1",
        "semver": "^7.5.2",
        "typed_janus_js": "^1.0.14",
        "uuid": "^14.0.0",
        "vue-load-image": "^0.2.0",
        "vue": "^3.5.35",
        "vue-echarts": "^7.0.3",
        "vue-i18n": "^11.0.0",
        "vue-inline-svg": "^4.0.1",
        "vue-observe-visibility": "^2.0.0-alpha.1",
        "vue-router": "^4.5.0",
        "vue-toast-notification": "^3.1.3",
        "vuedraggable": "^4.1.0",
        "vuetify": "^3.7.0",
        "vuex": "^4.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@mdi/js": "^7.0.0",
        "@types/file-saver": "^2.0.5",
        "@types/jmuxer": "^2.0.3",
        "@types/lodash.kebabcase": "^4.1.6",
        "@types/lodash.throttle": "^4.1.6",
        "@types/node": "^20.19.0",
        "@vitejs/plugin-vue": "^5.2.0",
        "@vitest/coverage-v8": "^3.2.6",
        "@vue/eslint-config-typescript": "^14.0.0",
        "@vue/test-utils": "^2.4.11",
        "autoprefixer": "^10.4.2",
        "cypress": "^15.15.0",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-jsonc": "^2.21.0",
        "eslint-plugin-vue": "^10.0.0",
        "globals": "^15.0.0",
        "happy-dom": "^20.10.3",
        "postcss": "^8.5.13",
        "postcss-nesting": "^12.0.1",
        "prettier": "^3.3.3",
        "prettier-plugin-sort-json": "^4.0.0",
        "sass": "^1.97.2",
        "start-server-and-test": "^2.0.5",
        "stream-browserify": "^3.0.0",
        "typescript": "^5.7.0",
        "unplugin-vue-components": "^0.22.12",
        "vite": "^7.3.5",
        "vite-plugin-package-version": "^1.1.0",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^3.2.6",
        "workbox-core": "^7.0.0"
    },
    "postcss": {
        "plugins": {
            "autoprefixer": {}
        }
    },
    "browserslist": [
        "> 1%",
        "not dead",
        "not op_mini all",
        "last 10 chrome major versions",
        "last 5 firefox major versions",
        "safari 12",
        "last 2 opera major versions",
        "last 2 edge major versions"
    ],
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "overrides": {
        "lodash": ">=4.17.23"
    },
    "trustedDependencies": [
        "@parcel/watcher",
        "core-js"
    ]
}
